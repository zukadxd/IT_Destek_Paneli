@model IT_Destek_Panel.Models.Ticket
@{
    ViewData["Title"] = "Yeni Talep Oluştur";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0" style="border-radius: 15px;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); border-radius: 15px 15px 0 0;">
                    <h4 class="mb-0 fw-bold"><i class="fa-solid fa-ticket-simple me-2"></i> Yeni IT Destek Talebi</h4>
                </div>
                
                <div class="card-body p-4 bg-light" style="border-radius: 0 0 15px 15px;">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger shadow-sm fw-bold mb-4">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Error
                        </div>
                    }

                    <form action="/Ticket/Create" method="post" enctype="multipart/form-data">
                        <div class="row mb-3">
                            <div class="col-md-8">
                                <label class="form-label fw-bold text-secondary">Konu Başlığı</label>
                                <input type="text" name="title" class="form-control form-control-lg border-primary" placeholder="Örn: Bilgisayarım açılmıyor" maxlength="100" required>
                            </div>
                            
                            <div class="col-md-4">
                                <label class="form-label fw-bold text-secondary">Aciliyet Seviyesi</label>
                                <select name="priorityId" class="form-select form-select-lg border-primary" asp-items="ViewBag.PriorityList" required>
                                    <option value="">Seçiniz...</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Sorun Detayı</label>
                            <textarea name="description" id="GelismişEditor" class="form-control border-primary" rows="5" placeholder="Lütfen yaşadığınız sorunu detaylıca anlatın..."></textarea>
                        </div>

                        <div class="card bg-light border-info mb-3 shadow-sm">
                            <div class="card-body py-2">
                                <label class="form-label small mb-0 fw-bold"><i class="fa-solid fa-paperclip"></i> Ekran Görüntüsü veya Dosya Ekle (İsteğe Bağlı)</label>
                                <input type="file" name="attachment" class="form-control form-control-sm mt-1">
                                <div class="form-text small text-muted">Sadece .jpg, .png veya .pdf dosyaları kabul edilir.</div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/Ticket/Index" class="btn btn-outline-secondary px-4 fw-bold">İptal</a>
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow fw-bold">
                                Talebi Gönder <i class="fa-solid fa-paper-plane ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        let editorInstance;

        document.addEventListener("DOMContentLoaded", function () {
        ClassicEditor
        .create(document.querySelector('#GelismişEditor'), {
        toolbar: ['heading', '|', 'bold', 'italic', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo']
        })
        .then(editor => {
        editorInstance = editor;
        updateEditorTheme(); // Sayfa açıldığında temayı uyarla
        })
        .catch(error => { console.error(error); });

        // Dark Mode ile Editörü Senkronize Eden Fonksiyon
        function updateEditorTheme() {
        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
        const editorArea = document.querySelector('.ck-editor__editable');
        const toolbarArea = document.querySelector('.ck-toolbar');

        if (editorArea) {
        editorArea.style.backgroundColor = isDark ? '#2b3035' : '#ffffff';
        editorArea.style.color = isDark ? '#f8f9fa' : '#212529';
        }
        if (toolbarArea) {
        toolbarArea.style.backgroundColor = isDark ? '#212529' : '#f8f9fa';
        }
        }

        // Tema değişimini izle (darkModeToggle butonu üzerinden)
        const themeToggleBtn = document.getElementById('darkModeToggle');
        if (themeToggleBtn) {
        themeToggleBtn.addEventListener('click', () => {
        setTimeout(updateEditorTheme, 50); // Tema değişiminden hemen sonra çalıştır
        });
        }
        });
    </script>
}

<style>
    .ck-editor__editable_inline {
    min-height: 250px !important;
    }
    [data-bs-theme="dark"] .ck.ck-editor__main > .ck-editor__editable {
    border-color: #495057 !important;
    }

    [data-bs-theme="dark"] .ck.ck-toolbar {
    border-color: #495057 !important;
    }
</style>